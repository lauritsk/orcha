amends "package://github.com/jdx/hk/releases/download/v1.44.1/hk@1.44.1#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.44.1/hk@1.44.1#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["ruff"] = Builtins.ruff
  ["ruff-format"] = Builtins.ruff_format
  ["ty"] = Builtins.ty
  ["pkl"] = Builtins.pkl
  ["pkl-format"] = Builtins.pkl_format
  ["tombi"] = Builtins.tombi
  ["tombi-format"] = Builtins.tombi_format
  ["rumdl"] = Builtins.rumdl
  ["goreleaser"] = new Step {
    glob = ".goreleaser.yaml"
    check = "goreleaser check"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
  ["commit-msg"] {
    steps {
      ["cocogitto-commit-msg"] {
        check = "cog --quiet verify --file {{commit_msg_file}}"
      }
    }
  }
}
